{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://opentp.dev/schemas/2025-12/field.schema.json",
  "title": "OpenTrackPlan Field",
  "description": "Field definition. Use 'value' for fixed values, 'enum' or 'dict' for allowed values",
  "type": "object",
  "allOf": [
    {
      "not": {
        "required": ["enum", "dict"]
      }
    },
    {
      "not": {
        "required": ["enum", "value"]
      }
    },
    {
      "not": {
        "required": ["dict", "value"]
      }
    }
  ],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Human-readable field name"
    },
    "description": {
      "type": "string",
      "description": "Field description"
    },
    "type": {
      "type": "string",
      "description": "Data type",
      "enum": ["string", "number", "boolean"]
    },
    "enum": {
      "type": "array",
      "description": "List of allowed values for this field"
    },
    "dict": {
      "type": "string",
      "description": "Reference to a dictionary (e.g., 'taxonomy/apps')"
    },
    "required": {
      "type": "boolean",
      "description": "Whether this field is required"
    },
    "value": {
      "description": "Fixed value for this field (string, number, or boolean)"
    },
    "checks": {
      "type": "object",
      "description": "Validation checks for this field",
      "additionalProperties": true
    },
    "pii": {
      "type": "object",
      "description": "PII metadata and masking configuration for this field",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "description": "PII kind identifier (reserved; configured in opentp.yaml)"
        },
        "masker": {
          "type": "string",
          "description": "Masker implementation id (reserved; configured in opentp.yaml)"
        }
      }
    }
  }
}
