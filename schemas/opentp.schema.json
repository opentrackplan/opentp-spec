{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://opentp.dev/schemas/2025-12/opentp.schema.json",
  "title": "OpenTrackPlan Configuration",
  "description": "Schema for opentp.yaml - the main configuration file",
  "type": "object",
  "required": ["opentp", "info", "spec"],
  "additionalProperties": false,
  "properties": {
    "opentp": {
      "$ref": "version.schema.json"
    },
    "info": {
      "type": "object",
      "description": "Project metadata",
      "required": ["title", "version"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Project title"
        },
        "description": {
          "type": "string",
          "description": "Project description"
        },
        "version": {
          "type": "string",
          "description": "Project version"
        },
        "contact": {
          "type": "array",
          "description": "Contact information",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "Specification",
      "required": ["paths", "events"],
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "object",
          "description": "File paths configuration",
          "required": ["events"],
          "additionalProperties": false,
          "properties": {
            "events": {
              "$ref": "#/definitions/eventsPathConfig"
            },
            "dictionaries": {
              "$ref": "#/definitions/dictionariesPathConfig"
            }
          }
        },
        "events": {
          "type": "object",
          "description": "Events configuration",
          "required": ["key", "taxonomy", "payload"],
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "object",
              "description": "Event key format",
              "required": ["pattern"],
              "additionalProperties": false,
              "properties": {
                "pattern": {
                  "type": "string",
                  "description": "Pattern for generating event keys"
                }
              }
            },
            "taxonomy": {
              "type": "object",
              "description": "Taxonomy fields definition",
              "additionalProperties": {
                "$ref": "#/definitions/taxonomyField"
              }
            },
            "payload": {
              "type": "object",
              "description": "Payload configuration",
              "required": ["targets", "schema"],
              "additionalProperties": false,
              "properties": {
                "targets": {
                  "type": "object",
                  "description": "Target definitions. 'all' is required",
                  "required": ["all"],
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "schema": {
                  "type": "object",
                  "description": "Payload fields schema",
                  "additionalProperties": {
                    "$ref": "field.schema.json"
                  }
                }
              }
            },
            "pii": {
              "$ref": "#/definitions/piiConfig"
            }
          }
        },
        "transforms": {
          "type": "object",
          "description": "Transform definitions",
          "additionalProperties": {
            "$ref": "#/definitions/transform"
          }
        }
      }
    }
  },
  "definitions": {
    "eventsPathConfig": {
      "type": "object",
      "description": "Path configuration for event files",
      "required": ["root", "pattern"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "Root directory path"
        },
        "pattern": {
          "type": "string",
          "description": "File name pattern"
        }
      }
    },
    "dictionariesPathConfig": {
      "type": "object",
      "description": "Path configuration for dictionary files",
      "required": ["root"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "Root directory path"
        }
      }
    },
    "taxonomyField": {
      "type": "object",
      "description": "Taxonomy field definition",
      "required": ["title", "type"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "type": {
          "type": "string",
          "description": "Data type",
          "enum": ["string", "number", "boolean"]
        },
        "required": {
          "type": "boolean",
          "description": "Whether this field is required"
        },
        "pattern": {
          "type": "string",
          "description": "Pattern for composite fields"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values"
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'taxonomy/apps')"
        },
        "checks": {
          "type": "object",
          "description": "Validation checks for this field",
          "additionalProperties": true
        },
        "fragments": {
          "type": "object",
          "description": "Sub-fields for composite fields",
          "additionalProperties": {
            "$ref": "#/definitions/taxonomyField"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        },
        {
          "oneOf": [
            {
              "not": {
                "required": ["enum"]
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "string" },
                "enum": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "number" },
                "enum": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "boolean" },
                "enum": {
                  "type": "array",
                  "items": { "type": "boolean" }
                }
              }
            }
          ]
        }
      ]
    },
    "piiConfig": {
      "type": "object",
      "description": "PII metadata configuration for payload fields",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/piiReservedFieldConfig"
        },
        "masker": {
          "$ref": "#/definitions/piiReservedFieldConfig"
        },
        "schema": {
          "type": "object",
          "description": "Additional PII metadata fields (validated by tooling)",
          "additionalProperties": {
            "$ref": "#/definitions/piiMetaField"
          }
        }
      }
    },
    "piiReservedFieldConfig": {
      "type": "object",
      "description": "Configuration for reserved PII fields (pii.kind, pii.masker)",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this PII field is required when pii is present"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values",
          "items": {
            "type": "string"
          }
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'governance/pii-kinds')"
        },
        "checks": {
          "type": "object",
          "description": "Validation checks for this field",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        }
      ]
    },
    "piiMetaField": {
      "type": "object",
      "description": "Additional PII metadata field definition",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "type": {
          "type": "string",
          "description": "Data type",
          "enum": ["string", "number", "boolean"]
        },
        "required": {
          "type": "boolean",
          "description": "Whether this field is required when pii is present"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values"
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'governance/pii-owners')"
        },
        "checks": {
          "type": "object",
          "description": "Validation checks for this field",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        },
        {
          "oneOf": [
            {
              "not": {
                "required": ["enum"]
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "string" },
                "enum": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "number" },
                "enum": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              }
            },
            {
              "required": ["enum"],
              "properties": {
                "type": { "const": "boolean" },
                "enum": {
                  "type": "array",
                  "items": { "type": "boolean" }
                }
              }
            }
          ]
        }
      ]
    },
    "transformStep": {
      "description": "Transform step. Either a string step name (e.g. 'lower') or an object mapping step name to params (e.g. { replace: { from: ' ', to: '_' } }).",
      "oneOf": [
        {
          "type": "string",
          "description": "Step name (built-in or custom)"
        },
        {
          "type": "object",
          "description": "Step with parameters: { <stepName>: <params> }",
          "minProperties": 1,
          "maxProperties": 1,
          "oneOf": [
            {
              "required": ["replace"],
              "additionalProperties": false,
              "properties": {
                "replace": {
                  "$ref": "#/definitions/replaceStepParams"
                }
              }
            },
            {
              "required": ["truncate"],
              "additionalProperties": false,
              "properties": {
                "truncate": {
                  "$ref": "#/definitions/truncateStepParams"
                }
              }
            },
            {
              "not": {
                "anyOf": [
                  { "required": ["replace"] },
                  { "required": ["truncate"] }
                ]
              },
              "additionalProperties": true
            }
          ]
        }
      ]
    },
    "replaceStepParams": {
      "type": "object",
      "description": "Literal replace configuration",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string",
          "description": "String to replace"
        },
        "to": {
          "type": "string",
          "description": "Replacement string"
        }
      }
    },
    "truncateStepParams": {
      "type": "integer",
      "description": "Maximum length",
      "minimum": 1
    },
    "transform": {
      "type": "array",
      "description": "Transform pipeline steps",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/transformStep"
      }
    }
  }
}
