{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://opentp.dev/schemas/2026-01/opentp.schema.json",
  "title": "OpenTrackPlan Configuration",
  "description": "Schema for opentp.yaml - the main configuration file",
  "type": "object",
  "required": ["opentp", "info", "spec"],
  "additionalProperties": false,
  "properties": {
    "opentp": {
      "$ref": "version.schema.json"
    },
    "info": {
      "type": "object",
      "description": "Project metadata",
      "required": ["title", "version"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Project title"
        },
        "description": {
          "type": "string",
          "description": "Project description"
        },
        "version": {
          "type": "string",
          "description": "Project version"
        },
        "contact": {
          "type": "array",
          "description": "Contact information",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "Specification",
      "required": ["paths", "events"],
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "object",
          "description": "File paths configuration",
          "required": ["events"],
          "additionalProperties": false,
          "properties": {
            "events": {
              "$ref": "#/definitions/eventsPathConfig"
            },
            "dictionaries": {
              "$ref": "#/definitions/dictionariesPathConfig"
            }
          }
        },
        "targets": {
          "type": "object",
          "description": "Target definitions (tooling-defined semantics). Keys are target IDs (e.g. 'ios-ga').",
          "additionalProperties": {
            "$ref": "#/definitions/targetConfig"
          }
        },
        "events": {
          "type": "object",
          "description": "Events configuration",
          "required": ["taxonomy", "payload"],
          "additionalProperties": false,
          "properties": {
            "key": {
              "$ref": "#/definitions/eventKeyConstraints"
            },
            "x-opentp": {
              "$ref": "#/definitions/xOpentpEvents"
            },
            "taxonomy": {
              "type": "object",
              "description": "Taxonomy fields definition",
              "additionalProperties": {
                "$ref": "#/definitions/taxonomyField"
              }
            },
            "payload": {
              "type": "object",
              "description": "Payload configuration",
              "required": ["targets", "schema"],
              "additionalProperties": false,
              "properties": {
                "targets": {
                  "type": "object",
                  "description": "Target definitions. 'all' is required",
                  "required": ["all"],
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "schema": {
                  "type": "object",
                  "description": "Payload fields schema",
                  "additionalProperties": {
                    "$ref": "field.schema.json"
                  }
                }
              }
            },
            "pii": {
              "$ref": "#/definitions/piiConfig"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "eventsPathConfig": {
      "type": "object",
      "description": "Path configuration for event files",
      "required": ["root", "template"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "Root directory path"
        },
        "template": {
          "type": "string",
          "description": "Path template using taxonomy fields (e.g. '{area}/{event}.yaml')"
        }
      }
    },
    "dictionariesPathConfig": {
      "type": "object",
      "description": "Path configuration for dictionary files",
      "required": ["root"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "Root directory path"
        }
      }
    },
    "xOpentpField": {
      "type": "object",
      "description": "OpenTrackPlan extensions (tooling-defined).",
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "Field role hint for tooling (does not affect schema validation).",
          "enum": ["constant", "attribute", "shared"]
        },
        "checks": {
          "type": "object",
          "description": "Tooling-defined validation checks (non-portable).",
          "additionalProperties": true
        }
      }
    },
    "eventKeyConstraints": {
      "type": "object",
      "description": "Constraints for event.key values (opaque string identifier). No key generation is defined in the core spec.",
      "additionalProperties": false,
      "properties": {
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum key length"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum key length"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for event keys"
        },
        "format": {
          "type": "string",
          "description": "String format hint (tooling may validate)",
          "enum": ["date", "date-time", "email", "uuid", "uri", "ipv4", "ipv6"]
        }
      }
    },
    "xOpentpEvents": {
      "type": "object",
      "description": "OpenTrackPlan extensions for spec.events (tooling-defined).",
      "additionalProperties": false,
      "properties": {
        "keygen": {
          "type": "object",
          "description": "Tooling-defined event key generation config (reference CLI can validate and auto-fix keys).",
          "required": ["template"],
          "additionalProperties": false,
          "properties": {
            "template": {
              "type": "string",
              "description": "Template for generating event keys from taxonomy values (e.g. '{area | slug}::{event | slug}')."
            },
            "transforms": {
              "type": "object",
              "description": "Transform definitions used by keygen templates",
              "additionalProperties": {
                "$ref": "#/definitions/transform"
              }
            }
          }
        }
      }
    },
    "targetConfig": {
      "type": "object",
      "description": "Target configuration (per target ID, e.g. 'ios-ga').",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable name"
        },
        "description": {
          "type": "string",
          "description": "Target description"
        },
        "schema": {
          "type": "object",
          "description": "Base/shared schema for this target (merged into every event payload for this target).",
          "additionalProperties": {
            "$ref": "field.schema.json"
          }
        }
      }
    },
    "taxonomyField": {
      "type": "object",
      "description": "Taxonomy field definition",
      "required": ["title", "type"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "type": {
          "type": "string",
          "description": "Data type",
          "enum": ["string", "number", "integer", "boolean"]
        },
        "required": {
          "type": "boolean",
          "description": "Whether this field is required"
        },
        "template": {
          "type": "string",
          "description": "Template for composite fields using fragments (e.g. '{verb} - {object}')"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values"
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'taxonomy/apps')"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length (type: string)"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length (type: string)"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern constraint (type: string)"
        },
        "format": {
          "type": "string",
          "description": "String format hint (tooling may validate)",
          "enum": ["date", "date-time", "email", "uuid", "uri", "ipv4", "ipv6"]
        },
        "minimum": {
          "type": "number",
          "description": "Minimum numeric value (type: number | integer)"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum numeric value (type: number | integer)"
        },
        "exclusiveMinimum": {
          "type": "number",
          "description": "Exclusive minimum numeric value (type: number | integer)"
        },
        "exclusiveMaximum": {
          "type": "number",
          "description": "Exclusive maximum numeric value (type: number | integer)"
        },
        "multipleOf": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Numeric multiple constraint (type: number | integer)"
        },
        "fragments": {
          "type": "object",
          "description": "Sub-fields for composite fields",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/taxonomyField"
          }
        },
        "x-opentp": {
          "$ref": "#/definitions/xOpentpField"
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        },
        {
          "oneOf": [
            {
              "not": {
                "anyOf": [{ "required": ["template"] }, { "required": ["fragments"] }]
              }
            },
            {
              "required": ["template", "fragments"]
            }
          ]
        },
        {
          "oneOf": [
            {
              "properties": {
                "type": { "const": "string" },
                "enum": { "type": "array", "items": { "type": "string" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["minimum"] },
                  { "required": ["maximum"] },
                  { "required": ["exclusiveMinimum"] },
                  { "required": ["exclusiveMaximum"] },
                  { "required": ["multipleOf"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "number" },
                "enum": { "type": "array", "items": { "type": "number" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["template"] },
                  { "required": ["fragments"] },
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "integer" },
                "enum": { "type": "array", "items": { "type": "integer" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["template"] },
                  { "required": ["fragments"] },
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "boolean" },
                "enum": { "type": "array", "items": { "type": "boolean" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["template"] },
                  { "required": ["fragments"] },
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] },
                  { "required": ["minimum"] },
                  { "required": ["maximum"] },
                  { "required": ["exclusiveMinimum"] },
                  { "required": ["exclusiveMaximum"] },
                  { "required": ["multipleOf"] }
                ]
              }
            }
          ]
        }
      ]
    },
    "piiConfig": {
      "type": "object",
      "description": "PII metadata configuration for payload fields",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/piiReservedFieldConfig"
        },
        "masker": {
          "$ref": "#/definitions/piiReservedFieldConfig"
        },
        "schema": {
          "type": "object",
          "description": "Additional PII metadata fields (validated by tooling)",
          "additionalProperties": {
            "$ref": "#/definitions/piiMetaField"
          }
        }
      }
    },
    "piiReservedFieldConfig": {
      "type": "object",
      "description": "Configuration for reserved PII fields (pii.kind, pii.masker)",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this PII field is required when pii is present"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values",
          "items": {
            "type": "string"
          }
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'governance/pii-kinds')"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern constraint"
        },
        "format": {
          "type": "string",
          "description": "String format hint (tooling may validate)",
          "enum": ["date", "date-time", "email", "uuid", "uri", "ipv4", "ipv6"]
        },
        "x-opentp": {
          "$ref": "#/definitions/xOpentpField"
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        }
      ]
    },
    "piiMetaField": {
      "type": "object",
      "description": "Additional PII metadata field definition",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable field name"
        },
        "description": {
          "type": "string",
          "description": "Field description"
        },
        "type": {
          "type": "string",
          "description": "Data type",
          "enum": ["string", "number", "integer", "boolean"]
        },
        "required": {
          "type": "boolean",
          "description": "Whether this field is required when pii is present"
        },
        "enum": {
          "type": "array",
          "description": "Inline list of allowed values"
        },
        "dict": {
          "type": "string",
          "description": "Reference to dictionary (e.g., 'governance/pii-owners')"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length (type: string)"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length (type: string)"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern constraint (type: string)"
        },
        "format": {
          "type": "string",
          "description": "String format hint (tooling may validate)",
          "enum": ["date", "date-time", "email", "uuid", "uri", "ipv4", "ipv6"]
        },
        "minimum": {
          "type": "number",
          "description": "Minimum numeric value (type: number | integer)"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum numeric value (type: number | integer)"
        },
        "exclusiveMinimum": {
          "type": "number",
          "description": "Exclusive minimum numeric value (type: number | integer)"
        },
        "exclusiveMaximum": {
          "type": "number",
          "description": "Exclusive maximum numeric value (type: number | integer)"
        },
        "multipleOf": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Numeric multiple constraint (type: number | integer)"
        },
        "x-opentp": {
          "$ref": "#/definitions/xOpentpField"
        }
      },
      "allOf": [
        {
          "not": {
            "required": ["enum", "dict"]
          }
        },
        {
          "oneOf": [
            {
              "properties": {
                "type": { "const": "string" },
                "enum": { "type": "array", "items": { "type": "string" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["minimum"] },
                  { "required": ["maximum"] },
                  { "required": ["exclusiveMinimum"] },
                  { "required": ["exclusiveMaximum"] },
                  { "required": ["multipleOf"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "number" },
                "enum": { "type": "array", "items": { "type": "number" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "integer" },
                "enum": { "type": "array", "items": { "type": "integer" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] }
                ]
              }
            },
            {
              "properties": {
                "type": { "const": "boolean" },
                "enum": { "type": "array", "items": { "type": "boolean" } }
              },
              "not": {
                "anyOf": [
                  { "required": ["minLength"] },
                  { "required": ["maxLength"] },
                  { "required": ["pattern"] },
                  { "required": ["format"] },
                  { "required": ["minimum"] },
                  { "required": ["maximum"] },
                  { "required": ["exclusiveMinimum"] },
                  { "required": ["exclusiveMaximum"] },
                  { "required": ["multipleOf"] }
                ]
              }
            }
          ]
        }
      ]
    },
    "transformStep": {
      "description": "Transform step. Either a string step name (e.g. 'lower') or an object mapping step name to params (e.g. { replace: { from: ' ', to: '_' } }).",
      "oneOf": [
        {
          "type": "string",
          "description": "Step name (built-in or custom)"
        },
        {
          "type": "object",
          "description": "Step with parameters: { <stepName>: <params> }",
          "minProperties": 1,
          "maxProperties": 1,
          "oneOf": [
            {
              "required": ["replace"],
              "additionalProperties": false,
              "properties": {
                "replace": {
                  "$ref": "#/definitions/replaceStepParams"
                }
              }
            },
            {
              "required": ["truncate"],
              "additionalProperties": false,
              "properties": {
                "truncate": {
                  "$ref": "#/definitions/truncateStepParams"
                }
              }
            },
            {
              "not": {
                "anyOf": [
                  { "required": ["replace"] },
                  { "required": ["truncate"] }
                ]
              },
              "additionalProperties": true
            }
          ]
        }
      ]
    },
    "replaceStepParams": {
      "type": "object",
      "description": "Literal replace configuration",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string",
          "description": "String to replace"
        },
        "to": {
          "type": "string",
          "description": "Replacement string"
        }
      }
    },
    "truncateStepParams": {
      "type": "integer",
      "description": "Maximum length",
      "minimum": 1
    },
    "transform": {
      "type": "array",
      "description": "Transform pipeline steps",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/transformStep"
      }
    }
  }
}
